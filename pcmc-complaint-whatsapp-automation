// ── Mobile format — 91 एकदाच ─────────────────────────────────────────────
function formatMobile(raw) {
  var num = String(raw).replace(/\D/g, '');
  return num.startsWith('91') ? num : '91' + num;
}

// ── WhatsApp msg पाठवणे ───────────────────────────────────────────────────
function sendWhatsApp(mobile, templateName, parameters) {
  var waPayload = {
    to: mobile,
    recipient_type: 'individual',
    type: 'template',
    template: {
      language: { policy: 'deterministic', code: 'en' },
      name: templateName,
      components: [{
        type: 'body',
        parameters: parameters
      }]
    }
  };

  Logger.log('Sending to: ' + mobile + ' | Template: ' + templateName);
  Logger.log('Parameters: ' + JSON.stringify(parameters));

  var waResponse = UrlFetchApp.fetch(WA_API_URL, {
    method: 'post',
    contentType: 'application/json',
    headers: { 'Authorization': 'Bearer ' + WA_TOKEN },
    payload: JSON.stringify(waPayload),
    muteHttpExceptions: true
  });

  var responseText = waResponse.getContentText();
  Logger.log('Response Code: ' + waResponse.getResponseCode());
  Logger.log('Response: ' + responseText);

  var waResult  = JSON.parse(responseText);
  var timestamp = Utilities.formatDate(new Date(), 'Asia/Kolkata', 'dd-MM-yyyy HH:mm:ss');

  if (waResult.message && waResult.message.message_status === 'queued') {
    return '✅ Sent | ' + timestamp;
  } else if (waResult.messages && waResult.messages.length > 0) {
    return '✅ Sent | ' + timestamp;
  } else if (waResult.error) {
    return '❌ Failed | ' + waResult.error.message;
  } else {
    return '⚠️ ' + responseText;
  }
}

// ── Sheet Protect — एकदाच run करा ────────────────────────────────────────
function protectSheet() {
  var ss    = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName('तक्रारी | Complaints');

  // आधीचे protections काढा
  var ranges = sheet.getProtections(SpreadsheetApp.ProtectionType.RANGE);
  ranges.forEach(function(p) { p.remove(); });
  var sheets = sheet.getProtections(SpreadsheetApp.ProtectionType.SHEET);
  sheets.forEach(function(p) { p.remove(); });

  // पूर्ण sheet lock करा
  var protection = sheet.protect().setDescription('PCMC Sheet Protected');
  protection.setWarningOnly(false);

  // फक्त Status (L) आणि Assigned To (N) unlock करा
  protection.setUnprotectedRanges([
    sheet.getRange('L2:L1000'),  // Status ✅
    sheet.getRange('N2:N1000')   // Assigned To ✅
  ]);

  // फक्त owner edit करू शकतो
  var me = Session.getEffectiveUser();
  protection.addEditor(me);
  protection.removeEditors(protection.getEditors());
  if (protection.canDomainEdit()) {
    protection.setDomainEdit(false);
  }

  Logger.log('✅ Sheet protected!');
  SpreadsheetApp.getUi().alert('✅ Sheet lock झाली!\n\nफक्त Status (Col L) आणि Assigned To (Col N) edit होईल.');
}

// ── Form Submit — नवीन तक्रार ─────────────────────────────────────────────
function onFormSubmit(e) {
