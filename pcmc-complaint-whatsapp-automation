  var mobile    = formatMobile(rowData[2]);         // C - Mobile
  var email     = String(rowData[3]).trim();        // D - Email
  var dept1     = String(rowData[4]).trim();        // E - विभाग dropdown
  var dept2     = String(rowData[5]).trim();        // F - विभाग text
  var ward      = String(rowData[6]).trim();        // G - वॉर्ड
  var desc      = String(rowData[7]).trim();        // H - तक्रार विवरण
  var rawDate   = rowData[8];                       // I - तक्रार दिनांक
  var location  = String(rowData[9]).trim();        // J - Location
  var photo     = String(rowData[10]).trim();       // K - छायाचित्र
  var firstComp = String(rowData[11]).trim();       // L - First Complaint

  var department = dept1 !== '' ? dept1 : dept2;

  // Date format
  var incDate = '';
  if (rawDate instanceof Date) {
    incDate = Utilities.formatDate(rawDate, 'Asia/Kolkata', 'dd-MM-yyyy');
  } else {
    incDate = String(rawDate).trim();
  }

  // Validation
  if (!name || name === '') { Logger.log('❌ Name नाही'); return; }
  if (mobile.length < 12)  { Logger.log('❌ Mobile नाही'); return; }

  var sendTime    = Utilities.formatDate(new Date(), 'Asia/Kolkata', 'dd-MM-yyyy HH:mm:ss');
  var complaintId = 'PCMC-' + new Date().getFullYear() + '-' +
                    String(compSheet.getLastRow()).padStart(4, '0');

  // Complaint sheet — 14 columns
  compSheet.appendRow([
    complaintId,  // A(0)  - Complaint ID
    name,         // B(1)  - नाव ✅
    mobile,       // C(2)  - Mobile ✅
    email,        // D(3)  - Email ✅
    department,   // E(4)  - Department ✅
    ward,         // F(5)  - Ward ✅
    desc,         // G(6)  - Description ✅
    incDate,      // H(7)  - Date ✅
    location,     // I(8)  - Location ✅
    photo,        // J(9)  - Photo ✅
    firstComp,    // K(10) - First Complaint ✅
    'New',        // L(11) - Status
    '',           // M(12) - Messages
    ''            // N(13) - Assigned To
  ]);

  var newCompRow   = compSheet.getLastRow();
  var parameters   = TEMPLATES['New'].parameters(name, complaintId, department, '');
  var waStatusText = sendWhatsApp(mobile, 'new', parameters);

  // Form responses — Messages col (13)
  formSheet.getRange(lastFormRow, 13).setValue(waStatusText);
  formSheet.getRange(lastFormRow, 13).setBackground(
    waStatusText.indexOf('✅') !== -1 ? '#D6F0DC' : '#F8D7DA'
  );

  // Complaint sheet — Messages col M (13)
  compSheet.getRange(newCompRow, 13).setValue(waStatusText);
  compSheet.getRange(newCompRow, 13).setBackground(
    waStatusText.indexOf('✅') !== -1 ? '#D6F0DC' : '#F8D7DA'
  );

  // History log
  if (historySheet) {
    historySheet.appendRow([
      sendTime, name, mobile,
      department, ward,
      '—', 'New', 'new', waStatusText
    ]);
    historySheet.getRange(historySheet.getLastRow(), 9).setBackground(
      waStatusText.indexOf('✅') !== -1 ? '#D6F0DC' : '#F8D7DA'
