// ── Status Change — Complaint sheet edit ─────────────────────────────────
function onEditTrigger(e) {
  var sheet = e.range.getSheet();
  if (sheet.getName() !== "तक्रारी | Complaints") return;

  var col = e.range.getColumn();
  var row = e.range.getRow();
  if (row <= 1) return;
  if (col !== 12) return; // L = Status col 12

  var newStatus = String(e.range.getValue()).trim();
  if (!newStatus || !TEMPLATES[newStatus]) {
    Logger.log('❌ Template नाही: ' + newStatus);
    return;
  }

  var lock = LockService.getScriptLock();
  if (!lock.tryLock(3000)) { Logger.log('❌ Lock नाही'); return; }

  try {
    Utilities.sleep(1000);

    var rowData    = sheet.getRange(row, 1, 1, 14).getValues()[0];
    var id         = String(rowData[0]).trim();   // A(0)  - Complaint ID
    var name       = String(rowData[1]).trim();   // B(1)  - नाव
    var mobile     = formatMobile(rowData[2]);    // C(2)  - Mobile
    var department = String(rowData[4]).trim();   // E(4)  - Department
    var assignedTo = String(rowData[13]).trim();  // N(13) - Assigned To ✅
    var oldStatus  = e.oldValue || '—';
    var timestamp  = Utilities.formatDate(new Date(), 'Asia/Kolkata', 'dd-MM-yyyy HH:mm:ss');

    Logger.log('Name: ' + name + ' | Mobile: ' + mobile);
    Logger.log('Department: ' + department + ' | AssignedTo: ' + assignedTo);
    Logger.log('Status: ' + oldStatus + ' → ' + newStatus);

    if (!name || name === '') { Logger.log('❌ Name नाही'); return; }
    if (mobile.length < 12)  { Logger.log('❌ Mobile नाही'); return; }
    if (newStatus === String(oldStatus).trim()) { Logger.log('❌ Same status'); return; }

    // Duplicate check
    var cache    = CacheService.getScriptCache();
    var cacheKey = 'row_' + row + '_' + newStatus;
    if (cache.get(cacheKey)) { Logger.log('❌ Duplicate'); return; }
    cache.put(cacheKey, 'sent', 15);

    var template     = TEMPLATES[newStatus];
    var parameters   = template.parameters(name, id, department, assignedTo);
    var waStatusText = sendWhatsApp(mobile, template.name, parameters);

    // Messages col M (13)
    sheet.getRange(row, 13).setValue(waStatusText);
    sheet.getRange(row, 13).setBackground(
      waStatusText.indexOf('✅') !== -1 ? '#D6F0DC' : '#F8D7DA'
    );

    // History log
    var historySheet = e.source.getSheetByName('History');
    if (historySheet) {
      historySheet.appendRow([
        timestamp, name, mobile,
        department, assignedTo,
        oldStatus, newStatus,
        template.name, waStatusText
      ]);
      historySheet.getRange(historySheet.getLastRow(), 9).setBackground(
        waStatusText.indexOf('✅') !== -1 ? '#D6F0DC' : '#F8D7DA'
      );
    }

    Logger.log('✅ ' + template.name + ' | ' + id + ' | ' + name + ' | ' + oldStatus + ' → ' + newStatus);

  } finally {
    lock.releaseLock();
  }
}

